{
  "name": "loom",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A tiny runtime reactive UI core.",
  "license": "MIT",
  "author": "Janos Veres",
  "sideEffects": false,
  "scripts": {
    "test": "vitest run",
    "check": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "bench": "vitest bench --run",
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "build:loom": "vite build --config vite.loom.config.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./observe": "./src/observe.ts",
    "./dom": "./src/dom/index.ts",
    "./dom/vlist": "./src/dom/vlist.ts",
    "./devtools": "./src/devtools/index.ts",
    "./jsx-runtime": "./src/dom/jsx-runtime.ts",
    "./jsx-dev-runtime": "./src/dom/jsx-runtime.ts",
    "./html": "./src/html/index.ts",
    "./html/jsx-runtime": "./src/html/jsx-runtime.ts",
    "./html/jsx-dev-runtime": "./src/html/jsx-runtime.ts"
  },
  "dependencies": {
    "alien-signals": "3.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3",
    "vite": "8.1.0",
    "vitest": "^4.1.8"
  }
}
