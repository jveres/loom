{
  "name": "loom",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "description": "A tiny runtime reactive UI core.",
  "license": "MIT",
  "author": "Janos Veres",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jveres/loom.git"
  },
  "sideEffects": [
    "./dist/loom/defer.js",
    "./dist/loom/observe*.js",
    "./src/core/defer.ts",
    "./src/core/inspect.ts",
    "./src/observe.ts"
  ],
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "NODE_OPTIONS=--expose-gc vitest run",
    "check": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "bench": "vitest bench --run",
    "dev": "vite --host 127.0.0.1",
    "build": "vite build --config vite.loom.config.ts && rm -rf dist/types && tsc -p tsconfig.build.json",
    "build:demo": "vite build",
    "size": "pnpm run build && node scripts/size.mjs",
    "samples": "node scripts/samples.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/loom/loom.js"
    },
    "./defer": {
      "types": "./dist/types/core/defer.d.ts",
      "default": "./dist/loom/defer.js"
    },
    "./observe": {
      "types": "./dist/types/observe.d.ts",
      "default": "./dist/loom/observe.js"
    },
    "./async": {
      "types": "./dist/types/async/index.d.ts",
      "default": "./dist/loom/async.js"
    },
    "./settle": {
      "types": "./dist/types/settle.d.ts",
      "default": "./dist/loom/settle.js"
    },
    "./dom": {
      "types": "./dist/types/dom/index.d.ts",
      "default": "./dist/loom/dom.js"
    },
    "./dom/virtual-list": {
      "types": "./dist/types/dom/virtual-list.d.ts",
      "default": "./dist/loom/dom/virtual-list.js"
    },
    "./dom/scroll-fade": {
      "types": "./dist/types/dom/scroll-fade.d.ts",
      "default": "./dist/loom/dom/scroll-fade.js"
    },
    "./devtools": {
      "types": "./dist/types/devtools/index.d.ts",
      "default": "./dist/loom/devtools.js"
    },
    "./jsx-runtime": {
      "types": "./dist/types/dom/jsx-runtime.d.ts",
      "default": "./dist/loom/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/types/dom/jsx-runtime.d.ts",
      "default": "./dist/loom/jsx-runtime.js"
    },
    "./html": {
      "types": "./dist/types/html/index.d.ts",
      "default": "./dist/loom/html.js"
    },
    "./html/jsx-runtime": {
      "types": "./dist/types/html/jsx-runtime.d.ts",
      "default": "./dist/loom/html/jsx-runtime.js"
    },
    "./html/jsx-dev-runtime": {
      "types": "./dist/types/html/jsx-runtime.d.ts",
      "default": "./dist/loom/html/jsx-runtime.js"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/node": "^26.1.1",
    "alien-signals": "3.2.1",
    "idiomorph": "^0.7.4",
    "typescript": "7.0.2",
    "vite": "8.1.3",
    "vitest": "^4.1.10"
  }
}
