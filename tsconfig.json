{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "jsxImportSource": "loom",
    "types": ["node"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "paths": {
      "loom": ["./src/index.ts"],
      "loom/observe": ["./src/observe.ts"],
      "loom/async": ["./src/async/index.ts"],
      "loom/dom": ["./src/dom/index.ts"],
      "loom/dom/virtual-list": ["./src/dom/virtual-list.ts"],
      "loom/devtools": ["./src/devtools/index.ts"],
      "loom/html": ["./src/html/index.ts"],
      "loom/jsx-runtime": ["./src/dom/jsx-runtime.ts"],
      "loom/jsx-dev-runtime": ["./src/dom/jsx-runtime.ts"],
      "loom/html/jsx-runtime": ["./src/html/jsx-runtime.ts"],
      "loom/html/jsx-dev-runtime": ["./src/html/jsx-runtime.ts"]
    },
    "allowImportingTsExtensions": false,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noUncheckedSideEffectImports": true,
    "noEmit": true,
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true
  },
  "include": [
    "*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "bench/**/*.ts",
    "demo/**/*.ts",
    "demo/**/*.tsx"
  ]
}
